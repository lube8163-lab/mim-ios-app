"app.launch.preparing_ai_models" = "Preparando modelos de IA…";
"app_info.ai_backend_labels.body" = "Las publicaciones de imagen pueden mostrar qué backend de comprensión de imágenes produjo sus metadatos semánticos.\nEsto ayuda a interpretar diferencias en caption/prompt y variaciones en la reconstrucción.";
"app_info.ai_backend_labels.title" = "Etiquetas de backend de IA";
"app_info.disclaimer" = "Los resultados generados son referencias experimentales y no están garantizados ni respaldados por los proveedores del modelo.";
"app_info.github_repository" = "Repositorio de GitHub";
"app_info.image_generation.body" = "Stable Diffusion 1.5:\nGenera imágenes reconstruidas para la línea de tiempo y las listas de publicaciones.\nComo admite el flujo img2img con imagen inicial, es más adecuado para comparaciones centradas en la calidad.\n\nStable Diffusion 1.5 (LCM):\nOptimizado para una reconstrucción más rápida. Es más veloz que el modelo estándar, pero no usa el flujo de tipo img2img.\n\nImage Playground:\nEl generador de imágenes integrado de Apple. Puede reconstruir imágenes sin descargas adicionales.\nAlgunos prompts pueden fallar y los prompts con personas o figuras parecidas a personas pueden quedar restringidos por las reglas internas del modelo.\n\nAutomático:\nPrioriza Stable Diffusion y usa Image Playground como respaldo cuando hace falta.";
"app_info.image_generation.title" = "Modelos de generación de imágenes";
"app_info.image_understanding.body" = "SigLIP2:\nExtrae tags y características visuales, y luego construye captions y prompts con una canalización ligera.\nEn Modo Pro también se usa para evaluar la fidelidad semántica frente a imágenes regeneradas.\n\nQwen3.5-VL-0.8B:\nGenera directamente captions, prompts y tags a partir de la imagen.\nEs más pesado que SigLIP2, pero puede producir descripciones más contextuales.\n\nApple Vision:\nUsa el clasificador integrado del iPhone y el iPad para crear un prompt ligero sin descargas extra.\n\nAutomático:\nPrioriza los modelos instalados y recurre a Apple Vision cuando no hay ninguno.";
"app_info.image_understanding.title" = "Modelos de comprensión de imágenes";
"app_info.links" = "Enlaces";
"app_info.navigation_title" = "Información de la app";
"app_info.overview.body" = "Esta app es una red social experimental que trata las imágenes como representaciones semánticas o comprimidas en lugar de almacenar y compartir siempre los datos originales.\n\nAl publicar, los modelos de comprensión de imágenes pueden generar caption, prompts y tags.\nAl ver publicaciones, los modelos de generación pueden reconstruir imágenes en el dispositivo.\nIncluso sin modelos descargados, la app puede usar Apple Vision e Image Playground como respaldo.";
"app_info.overview.title" = "Resumen";
"app_info.post_modes.body" = "Los modos de publicación controlan cuánto de la información derivada de la imagen se conserva.\nLos modos más ligeros favorecen la privacidad, mientras que los más fuertes permiten reconstrucciones más fáciles.\n\nLa calidad de la reconstrucción depende del modo seleccionado, del modelo activo y del contenido de la imagen original.";
"app_info.post_modes.title" = "Modos de publicación";
"app_info.pro_mode.body" = "El Modo Pro muestra tanto la fidelidad semántica como la distancia perceptual LPIPS para tus propias publicaciones al comparar imágenes regeneradas con la original.\nTambién muestra el tiempo de generación del prompt, el tiempo de generación de la imagen y el uso de memoria para inspección.\n\nEstas métricas están pensadas para comparación y evaluación.\nLa memoria se muestra como la huella medida cuando termina cada paso, no como un pico máximo.\n\nLa distancia perceptual LPIPS está disponible desde el modelo integrado.\nSigLIP2 es necesario para calcular la fidelidad semántica.\nTambién puedes ajustar el presupuesto de caché desde Configuración cuando sea necesario.";
"app_info.pro_mode.title" = "Modo Pro";
