    "settings.alert.siglip_required.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro Mode is enabled. LPIPS perceptual distance is available, but SigLIP2 must be installed before semantic fidelity scores can be computed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El Modo Pro está activado. La distancia perceptual LPIPS está disponible, pero debes instalar SigLIP2 antes de calcular la fidelidad semántica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロモードは有効化されました。LPIPSによる知覚距離評価は使えますが、意味保持率の計算には SigLIP2 のインストールが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로 모드는 활성화되었습니다. LPIPS 지각 거리는 사용할 수 있지만, 의미 보존율을 계산하려면 SigLIP2를 설치해야 합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Modo Pro está ativado. A distância perceptual LPIPS está disponível, mas o SigLIP2 precisa estar instalado para calcular a fidelidade semântica."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "专业模式已启用。可以使用 LPIPS 感知距离评估，但要计算语义保持率仍需先安装 SigLIP2。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "专业模式已啟用。可以使用 LPIPS 感知距离评估，但要计算語義保持率仍需先安裝 SigLIP2。"
          }
        }
      }
    },
