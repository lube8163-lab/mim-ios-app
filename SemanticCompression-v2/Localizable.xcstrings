    "license.about.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app complies with the licenses of all models used.\nAll generation is performed on-device or initiated by explicit user actions.\nGenerated results are not endorsed or guaranteed by the model providers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app cumple con las licencias de todos los modelos utilizados.\nToda la generación se realiza en el dispositivo o se inicia mediante acciones explícitas del usuario.\nLos resultados generados no están garantizados ni respaldados por los proveedores del modelo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本アプリは、各モデルのライセンス条件を遵守し、\nオンデバイス処理またはユーザー操作を起点とした生成のみを行います。\n\n生成結果はモデル提供元によって保証されるものではありません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app cumpre as licenças de todos os modelos utilizados.\nToda geração é realizada no dispositivo ou iniciada por ações explícitas do usuário.\nOs resultados gerados não são garantidos nem endossados pelos provedores do modelo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本应用遵守所使用各模型的许可证条款。\n所有生成均在设备端执行，或由用户明确操作触发。\n生成结果不代表模型提供方的保证或认可。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本應用遵守所使用各模型的許可證條款。\n所有生成均在裝置端執行，或由使用者明確操作觸發。\n生成結果不代表模型提供方的保證或認可。"
          }
        }
      }
    },
