    "model_management.model.lcm.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM is tuned for speed. img2img (starting-image workflow) is disabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM está ajustado para velocidad. img2img (flujo con imagen inicial) está desactivado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM は高速生成向けです。img2img（元画像ベース）は無効化されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM은 속도 위주로 조정되어 있습니다. img2img(시작 이미지 워크플로)는 비활성화됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM é ajustado para velocidade. img2img (fluxo com imagem inicial) fica desativado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM 针对速度进行了优化。img2img（基于原图的流程）将被禁用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "LCM 針對速度進行了最佳化。img2img（基於原圖的流程）將被停用。"
          }
        }
      }
    },
    "model_management.model.qwen.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen generates caption, prompt, and tags directly from the image. It is heavier than SigLIP but can produce more contextual outputs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen genera captions, prompts y tags directamente a partir de la imagen. Es más pesado que SigLIP, pero puede producir resultados más contextuales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen は画像から caption / prompt / tags を直接生成します。SigLIP より重いですが、より文脈的な出力を狙えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen은 이미지에서 caption, prompt, tags를 직접 생성합니다. SigLIP보다 무겁지만 더 문맥적인 결과를 낼 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen gera captions, prompts e tags diretamente a partir da imagem. É mais pesado que o SigLIP, mas pode produzir saídas mais contextuais."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen 会直接从图像生成 caption / prompt / tags。它比 SigLIP 更重，但能提供更具上下文的信息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen 會直接從圖像生成 caption / prompt / tags。它比 SigLIP 更重，但能提供更具上下文的資訊。"
          }
        }
      }
    },
    "model_management.model.sd15.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The standard SD 1.5 model prioritizes reconstruction quality. It supports the starting-image img2img workflow, which makes it better for comparing privacy modes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modelo estándar SD 1.5 prioriza la calidad de reconstrucción. Admite el flujo img2img con imagen inicial, por lo que es mejor para comparar modos de privacidad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常版 SD1.5 は品質重視の再構成向けです。元画像ベースの img2img を使えるため、モード差の比較にも向いています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 SD 1.5 모델은 재구성 품질을 우선합니다. 시작 이미지를 사용하는 img2img 워크플로를 지원해 게시 모드 비교에 유리합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modelo SD 1.5 padrão prioriza a qualidade da reconstrução. Ele suporta o fluxo img2img com imagem inicial, o que o torna melhor para comparar modos de privacidade."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准版 SD 1.5 更偏向重建质量。它支持基于原图的 img2img 流程，更适合比较不同隐私模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "標準版 SD 1.5 更偏向重建品質。它支援基於原圖的 img2img 流程，更適合比較不同隱私模式。"
          }
        }
      }
    },
    "model_management.model.siglip.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 is a lightweight vision model that extracts embeddings and tags from images. It is used for caption/prompt assembly and is also required for Pro Mode semantic fidelity scoring."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 es un modelo de visión ligero que extrae embeddings y tags de imágenes. Se usa para construir captions/prompts y también es necesario para medir la fidelidad semántica en Modo Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 は画像から特徴量とタグを抽出する軽量モデルです。caption / prompt の組み立てに使われ、プロモードの意味保持率評価にも必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2는 이미지에서 임베딩과 태그를 추출하는 가벼운 비전 모델입니다. caption/prompt 조합에 사용되며 프로 모드 의미 보존율 계산에도 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 é um modelo de visão leve que extrai embeddings e tags de imagens. É usado para montar captions/prompts e também é necessário para medir a fidelidade semântica no Modo Pro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 是一个轻量级视觉模型，可从图像中提取特征和标签。它用于组装 caption / prompt，也用于 Pro Mode 的语义保真度评分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 是一個輕量級視覺模型，可從圖像中提取特徵和標籤。它用於組裝 caption / prompt，也用於 Pro Mode 的語義保真度評分。"
          }
        }
      }
    },
