    "app_info.post_modes.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Post modes control how much image-derived information is preserved.\nLighter modes favor privacy, while stronger modes allow easier reconstruction.\n\nReconstruction quality depends on the selected mode, the active model, and the content of the original image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los modos de publicación controlan cuánto de la información derivada de la imagen se conserva.\nLos modos más ligeros favorecen la privacidad, mientras que los más fuertes permiten reconstrucciones más fáciles.\n\nLa calidad de la reconstrucción depende del modo seleccionado, del modelo activo y del contenido de la imagen original."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "投稿モードでは、どの程度元画像に近い情報を残すかを選べます。\n軽いモードほど保護寄りになり、高いモードほど再構成しやすくなります。\n\n生成結果や再構成品質は、選択したモード、利用中モデル、元画像の内容によって変わります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os modos de postagem controlam quanto da informação derivada da imagem é preservada.\nModos mais leves favorecem a privacidade, enquanto modos mais fortes permitem reconstruções mais fáceis.\n\nA qualidade da reconstrução depende do modo selecionado, do modelo ativo e do conteúdo da imagem original."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发布模式决定会保留多少来自原图的信息。\n越轻的模式越偏向隐私保护，越强的模式越容易重建。\n\n重建质量取决于所选模式、当前使用的模型以及原图内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發布模式決定會保留多少來自原圖的資訊。\n越輕的模式越偏向隱私保護，越強的模式越容易重建。\n\n重建品質取決於所選模式、目前使用的模型以及原圖內容。"
          }
        }
      }
    },
    "app_info.post_modes.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Post Modes"
          }
        },
        "es": {
