    "settings.backend.image_generation.automatic": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic mode prefers Stable Diffusion and falls back to Image Playground when it is unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo automático prioriza Stable Diffusion y usa Image Playground cuando no está disponible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動選択です。Stable Diffusion があればそれを使い、無ければ Image Playground を使います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 모드는 Stable Diffusion을 우선 사용하고, 사용할 수 없으면 Image Playground로 전환합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo automático prioriza o Stable Diffusion e recorre ao Image Playground quando ele não está disponível."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动模式会优先使用 Stable Diffusion，不可用时改用 Image Playground。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自动模式會优先使用 Stable Diffusion，不可用時改用 Image Playground。"
          }
        }
      }
    },
    "settings.backend.image_generation.image_playground": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground is Apple's built-in generator and can reconstruct images without downloading extra models."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground es el generador integrado de Apple y puede reconstruir imágenes sin descargar modelos extra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground は Apple の標準生成機能です。モデル未導入でも端末だけで再構成画像を作れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground는 Apple의 내장 생성기로, 추가 모델 다운로드 없이 이미지를 재구성할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground é o gerador integrado da Apple e pode reconstruir imagens sem baixar modelos extras."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground 是 Apple 内建生成器，无需下载额外模型也能重建图像。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground 是 Apple 內建生成器，無需下載额外模型也能重建圖像。"
          }
        }
      }
    },
    "settings.backend.image_generation.stable_diffusion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion reconstructs images with downloaded models. The standard model supports img2img, while LCM is faster."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion reconstruye imágenes con modelos descargados. El modelo estándar admite img2img, mientras que LCM es más rápido."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion はダウンロード済みモデルで再構成します。通常版は img2img を使え、LCM は高速です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion은 다운로드한 모델로 이미지를 재구성합니다. 기본 모델은 img2img를 지원하고 LCM은 더 빠릅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion reconstrói imagens com modelos baixados. O modelo padrão suporta img2img, enquanto o LCM é mais rápido."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion 会用已下载模型进行重建。标准版支持 img2img，LCM 更快。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion 會用已下載模型进行重建。标准版支持 img2img，LCM 更快。"
          }
        }
      }
    },
    "settings.backend.image_understanding.automatic": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatic mode prefers installed models and falls back to Apple Vision when none are available."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo automático prioriza los modelos instalados y usa Apple Vision cuando no hay ninguno disponible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動選択です。追加モデルがあればそれを使い、無ければ Apple Vision にフォールバックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 모드는 설치된 모델을 우선 사용하고, 없으면 Apple Vision으로 전환합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo automático prioriza os modelos instalados e recorre ao Apple Vision quando nenhum está disponível."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动模式会优先使用已安装模型，没有时回退到 Apple Vision。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自动模式會优先使用已安裝模型，没有時回退到 Apple Vision。"
          }
        }
      }
    },
    "settings.backend.image_understanding.qwen": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL tends to generate captions, prompts, and tags more directly with richer context."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL tiende a generar captions, prompts y tags de forma más directa y con más contexto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL は caption / prompt / tags を直接生成しやすく、より文脈的な説明になりやすいです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL은 더 풍부한 문맥의 caption, prompt, tags를 직접 생성하는 경향이 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL tende a gerar captions, prompts e tags de forma mais direta e com contexto mais rico."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL 更容易直接生成 caption / prompt / tags，语境通常更丰富。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Qwen3.5-VL 更容易直接生成 caption / prompt / tags，语境通常更丰富。"
          }
        }
      }
    },
    "settings.backend.image_understanding.siglip2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 is a lighter, stable tag extractor and is also used for Pro Mode semantic fidelity scoring."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 es un extractor de tags más ligero y estable, y también se usa para evaluar la fidelidad semántica en Modo Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 は軽量で安定したタグ抽出に向いており、プロモードの意味保持率評価にも使われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2는 가볍고 안정적인 태그 추출기이며, 프로 모드 의미 보존율 계산에도 사용됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 é um extrator de tags mais leve e estável, e também é usado para medir a fidelidade semântica no Modo Pro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 更轻量，适合稳定提取标签，也用于专业模式的语义保持率评分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "SigLIP2 更轻量，适合稳定提取标簽，也用于专业模式的語義保持率评分。"
          }
        }
      }
    },
    "settings.backend.image_understanding.vision": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Vision performs lightweight tag classification and builds a simple prompt without extra downloads."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Vision realiza una clasificación ligera de tags y construye un prompt simple sin descargas extra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Vision で軽量なタグ分類を行い、簡易 prompt を作ります。追加ダウンロード不要で使えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Vision은 추가 다운로드 없이 가벼운 태그 분류와 간단한 프롬프트 생성을 수행합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Apple Vision faz uma classificação leve de tags e monta um prompt simples sem downloads extras."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Vision 会进行轻量标签分类，并生成简易 prompt，无需额外下载。"
