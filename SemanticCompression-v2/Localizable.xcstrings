    "settings.sd.options.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even for L2-L4 posts, Stable Diffusion will run without an init image and rely only on the semantic prompt. This reduces structural guidance, but can avoid blur or distortions introduced by the init image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incluso para publicaciones L2-L4, Stable Diffusion puede ejecutarse sin imagen inicial y apoyarse solo en el prompt semántico. Esto reduce la guía estructural, pero puede evitar desenfoque o distorsiones introducidas por la imagen inicial."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "L2〜L4 の投稿でも初期画像を使わず、semantic prompt のみで Stable Diffusion を実行します。構図の手がかりは減りますが、初期画像由来のノイズや崩れを避けたいときに有効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "L2-L4 게시물에서도 Stable Diffusion이 초기 이미지 없이 의미 프롬프트만으로 동작합니다. 구조적 가이드는 줄지만 초기 이미지에서 생기는 블러나 왜곡을 피할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesmo para postagens L2-L4, o Stable Diffusion pode rodar sem imagem inicial e depender apenas do prompt semântico. Isso reduz a orientação estrutural, mas pode evitar borrões ou distorções introduzidas pela imagem inicial."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使是 L2-L4 帖子，Stable Diffusion 也不会使用初始图像，而只依赖 semantic prompt。这样会减少构图引导，但有助于避免初始图像带来的噪声与变形。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即使是 L2-L4 帖子，Stable Diffusion 也不會使用初始圖像，而只依赖 semantic prompt。這样會减少构圖引導，但有助于避免初始圖像带來的噪声與变形。"
          }
        }
      }
    },
