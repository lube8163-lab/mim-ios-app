    "model_install.completed_toast": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Installation completed. Please restart the app for stable behavior."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La instalación ha finalizado. Reinicia la app para un comportamiento estable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インストールが完了しました。安定動作のためアプリを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설치가 완료되었습니다. 안정적인 동작을 위해 앱을 다시 실행해 주세요."
          }
        },
