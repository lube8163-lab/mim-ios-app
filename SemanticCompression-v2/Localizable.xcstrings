    "app_info.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generated outputs are experimental reference results and are not endorsed or guaranteed by model providers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los resultados generados son referencias experimentales y no están garantizados ni respaldados por los proveedores del modelo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "生成結果は研究用途の参考出力であり、モデル提供元によって保証・推奨されるものではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "생성 결과는 실험적 참고 출력이며, 모델 제공자가 보증하거나 권장하는 결과가 아닙니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As saídas geradas são referências experimentais e não são garantidas nem endossadas pelos provedores do modelo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "生成结果仅供研究和实验参考，不代表模型提供方的保证或推荐。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "生成結果僅供研究和實驗參考，不代表模型提供方的保證或推薦。"
          }
        }
      }
    },
