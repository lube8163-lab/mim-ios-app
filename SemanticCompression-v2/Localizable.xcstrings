    "settings.image_generation.regenerate_visible.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear cached images for currently visible posts and regenerate them with the selected image-generation model."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra la caché de imágenes de las publicaciones visibles y vuelve a generarlas con el modelo seleccionado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在表示している投稿画像のキャッシュを削除し、選択中の画像生成モデルで再生成します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 보이는 게시물의 캐시 이미지를 지우고 선택한 이미지 생성 모델로 다시 생성합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpa as imagens em cache das postagens visíveis e as regenera com o modelo de geração selecionado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除当前可见帖子图片的缓存，并使用当前选中的图像生成模型重新生成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清除当前可见帖子圖片的缓存，並使用当前选中的圖像生成模型重新生成。"
          }
        }
      }
    },
    "settings.image_playground.style.animation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation tends to produce softer, more playful-looking results."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation tiende a producir resultados más suaves y juguetones."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation はややポップで柔らかい見た目になりやすいスタイルです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation은 더 부드럽고 장난스러운 느낌의 결과를 만드는 경향이 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation tende a produzir resultados mais suaves e brincalhões."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation 往往会生成更柔和、更活泼的视觉效果。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Animation 往往會生成更柔和、更活泼的视觉效果。"
          }
        }
      }
    },
    "settings.image_playground.style.illustration": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration is the most balanced and default-looking style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration es el estilo más equilibrado y similar al predeterminado."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration は最も標準的で、バランスの良い見た目になりやすいスタイルです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration은 가장 균형 잡힌 기본 스타일입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration é o estilo mais equilibrado e com aparência padrão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration 是最均衡、最标准的一种风格。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Illustration 是最均衡、最标准的一种风格。"
          }
        }
