    "app_info.overview.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is an experimental social network that treats images as semantic or compressed representations instead of always storing and sharing the original image data.\n\nAt post time, image understanding models can generate captions, prompts, and tags.\nAt viewing time, image generation models can reconstruct timeline images on-device.\nEven without downloaded models, the app can fall back to Apple Vision and Image Playground."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app es una red social experimental que trata las imágenes como representaciones semánticas o comprimidas en lugar de almacenar y compartir siempre los datos originales.\n\nAl publicar, los modelos de comprensión de imágenes pueden generar caption, prompts y tags.\nAl ver publicaciones, los modelos de generación pueden reconstruir imágenes en el dispositivo.\nIncluso sin modelos descargados, la app puede usar Apple Vision e Image Playground como respaldo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは、画像をそのまま保存・共有するのではなく、意味情報や圧縮表現として扱い、必要に応じて端末上で再構成することを試す研究・実験的なSNSアプリです。\n\n投稿時には画像理解モデルで caption / prompt / tags を生成し、閲覧時には画像生成モデルで再構成画像を表示できます。\n追加モデルが無い場合でも、Apple Vision / Image Playground への自動フォールバックが使えます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app é uma rede social experimental que trata imagens como representações semânticas ou comprimidas, em vez de sempre armazenar e compartilhar os dados originais.\n\nAo postar, os modelos de entendimento de imagem podem gerar caption, prompts e tags.\nAo visualizar, os modelos de geração podem reconstruir imagens no dispositivo.\nMesmo sem modelos baixados, o app pode recorrer ao Apple Vision e ao Image Playground."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本应用是一个实验性的社交平台。它不会总是直接保存和分享原始图片，而是尝试把图像视为语义信息或压缩表示，并在需要时于设备端重建。\n\n发帖时，图像理解模型可以生成 caption、prompt 和 tags。\n浏览时，图像生成模型可以在设备上重建时间线图片。\n即使没有下载额外模型，也可以回退到 Apple Vision 和 Image Playground。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本應用是一個實驗性的社交平台。它不會總是直接保存和分享原始圖片，而是嘗試把圖像視為語義資訊或壓縮表示，並在需要時於裝置端重建。\n\n發帖時，圖像理解模型可以生成 caption、prompt 和 tags。\n瀏覽時，圖像生成模型可以在裝置上重建時間線圖片。\n即使沒有下載額外模型，也可以回退到 Apple Vision 和 Image Playground。"
          }
        }
      }
    },
    "app_info.overview.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
