    "onboarding.explainer.compress.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Instead of sending the full image, the app sends caption / prompt / tags and a lightweight image representation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En lugar de enviar la imagen completa, la app envía caption / prompt / tags y una representación ligera de la imagen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像そのものではなく、caption / prompt / tags と軽量な画像表現を送ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원본 이미지를 보내는 대신 caption / prompt / tags와 가벼운 이미지 표현을 전송합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em vez de enviar a imagem completa, o app envia caption / prompt / tags e uma representação leve da imagem."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用不会直接发送完整图片，而是发送 caption / prompt / tags 与轻量图像表示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用不會直接傳送完整圖片，而是傳送 caption / prompt / tags 與輕量圖像表示。"
          }
        }
      }
    },
