    "settings.pro_mode.clear_cache.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This clears regenerated image cache. It also removes retained originals, semantic scores, and LPIPS distances created by Pro Mode."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra la caché de imágenes regeneradas. También elimina originales retenidos, puntuaciones semánticas y distancias LPIPS creadas por el Modo Pro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作で再生成キャッシュを削除します。プロモードで保持した元画像キャッシュ、意味スコア、LPIPS知覚距離も削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재생성 이미지 캐시를 지웁니다. 프로 모드가 보관한 원본, 의미 점수, LPIPS 거리도 함께 삭제됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto limpa o cache de imagens regeneradas. Também remove originais retidos, pontuações semânticas e distâncias LPIPS criadas pelo Modo Pro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作会清除重建图片缓存，也会删除专业模式保留的原图缓存、语义评分和LPIPS感知距离。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作會清除重建圖片缓存，也會刪除专业模式保留的原圖缓存、語義评分和LPIPS感知距离。"
          }
        }
      }
    },
    "settings.pro_mode.memory_note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory usage is not a peak reading. It is the footprint measured when each step finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El uso de memoria no es un valor pico. Es la huella medida cuando termina cada paso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリ使用量はピーク値ではなく、各処理が終わった時点のフットプリントです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리 사용량은 피크값이 아니라 각 단계 완료 시점의 풋프린트입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O uso de memória não é um pico. É o footprint medido quando cada etapa termina."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内存使用量不是峰值，而是每个处理步骤完成时的占用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "內存使用量不是峰值，而是每个处理步骤完成時的占用。"
          }
        }
      }
    },
    "settings.pro_mode.siglip_missing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LPIPS perceptual distance is still available, but SigLIP2 is required for semantic fidelity scoring. You can enable Pro Mode without it, though semantic scores will stay unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La distancia perceptual LPIPS sigue disponible, pero SigLIP2 es necesario para la fidelidad semántica. Puedes activar el Modo Pro sin él, aunque las puntuaciones semánticas no estarán disponibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LPIPSによる知覚距離評価は利用できますが、意味保持率の計算には SigLIP2 モデルが必要です。未導入でもプロモードは有効化できますが、意味スコアは表示されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LPIPS 지각 거리는 사용할 수 있지만, 의미 보존율 계산에는 SigLIP2가 필요합니다. SigLIP2 없이도 프로 모드는 켤 수 있지만 의미 점수는 표시되지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A distância perceptual LPIPS continua disponível, mas o SigLIP2 é necessário para calcular a fidelidade semântica. Você pode ativar o Modo Pro sem ele, mas as pontuações semânticas ficarão indisponíveis."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使没有 SigLIP2，仍可使用 LPIPS 感知距离评估；但语义保持率计算仍需要 SigLIP2 模型。未安装时也可以开启专业模式，但不会显示语义评分。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即使没有 SigLIP2，仍可使用 LPIPS 感知距离评估；但語義保持率计算仍需要 SigLIP2 模型。未安裝時也可以開啟专业模式，但不會顯示語義评分。"
          }
        }
      }
    },
    "settings.pro_mode.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep original-image cache for your posts and show semantic fidelity, LPIPS perceptual distance, processing time, and memory usage for regenerated results. Memory is shown as the footprint at completion."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantiene la caché de imágenes originales de tus publicaciones y muestra fidelidad semántica, distancia perceptual LPIPS, tiempo de proceso y uso de memoria. La memoria se muestra como huella al finalizar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の投稿画像の元画像キャッシュを保持し、再生成結果との意味保持率、LPIPS知覚距離、処理時間、メモリ使用量を表示します。メモリ値は処理完了時点のフットプリントです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내 게시물의 원본 이미지 캐시를 유지하고, 의미 보존율, LPIPS 지각 거리, 처리 시간, 메모리 사용량을 표시합니다. 메모리는 완료 시점의 풋프린트입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantém o cache de imagens originais das suas postagens e mostra fidelidade semântica, distância perceptual LPIPS, tempo de processamento e uso de memória. A memória é mostrada como footprint ao finalizar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为你自己的帖子保留原图缓存，并显示与重建结果的语义保持率、LPIPS感知距离、处理时间和内存使用量。内存值显示的是每一步完成时的占用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為你自己的帖子保留原圖缓存，並顯示與重建结果的語義保持率、LPIPS感知距离、处理時间和內存使用量。內存值顯示的是每一步完成時的占用。"
          }
        }
      }
    },
