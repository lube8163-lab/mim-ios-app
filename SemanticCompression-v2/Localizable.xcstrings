    "model_management.error.integrity_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Verification failed after downloading %@. The file may be corrupted or different from the expected package. Please try downloading it again later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La verificación falló después de descargar %@. El archivo puede estar dañado o no coincidir con el paquete esperado. Intenta descargarlo de nuevo más tarde."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のダウンロード後検証に失敗しました。ファイルが壊れているか、配布内容が想定と一致していません。時間をおいて再ダウンロードしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 다운로드 후 검증에 실패했습니다. 파일이 손상되었거나 예상 패키지와 다를 수 있습니다. 나중에 다시 다운로드해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A verificação falhou após baixar %@. O arquivo pode estar corrompido ou diferente do pacote esperado. Tente baixar novamente mais tarde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载 %@ 后的校验失败。文件可能已损坏，或分发内容与预期不一致。请稍后重试下载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載 %@ 後的校驗失敗。檔案可能已損壞，或發行內容與預期不一致。請稍後重試下載。"
          }
        }
      }
    },
    "model_management.image_generation.notice": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Right after installing or switching an image-generation model, the app may briefly feel unresponsive while the model is loading. Wait a moment for preparation to finish, or restart the app if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Justo después de instalar o cambiar un modelo de generación, la app puede sentirse lenta mientras carga el modelo. Espera un momento o reinicia la app si hace falta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像生成モデルのインストール直後や切替直後は、モデル読み込みのため一時的にアプリ操作が重くなったり固まったように見えることがあります。完了まで少し待つか、必要に応じてアプリを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지 생성 모델을 설치하거나 전환한 직후에는 모델 로딩 때문에 앱이 잠시 느려질 수 있습니다. 준비가 끝날 때까지 기다리거나 필요하면 앱을 재시작해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Logo após instalar ou trocar um modelo de geração de imagem, o app pode ficar lento enquanto o modelo é carregado. Aguarde um momento ou reinicie o app se necessário."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刚安装或切换图像生成模型后，应用在加载模型时可能会暂时变卡或看起来像是无响应。请稍等片刻，必要时可重新启动应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "剛安裝或切換圖像生成模型後，應用在載入模型時可能會暫時變卡或看起來像是無回應。請稍等片刻，必要時可重新啟動應用。"
          }
        }
      }
    },
    "model_management.image_generation.playground_note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "With Image Playground, some prompts may fail to generate. Content involving people or person-like imagery may also be restricted by the model's built-in rules."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con Image Playground algunos prompts pueden fallar. El contenido con personas o imágenes similares a personas también puede estar restringido por las reglas del modelo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground では一部のプロンプトで画像生成に失敗することがあります。また、人物画像や人物表現を含む内容はモデル仕様上生成が制限される場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Playground에서는 일부 프롬프트 생성이 실패할 수 있습니다. 사람 또는 사람처럼 보이는 내용도 모델 규칙에 따라 제한될 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Com o Image Playground, alguns prompts podem falhar. Conteúdo com pessoas ou imagens parecidas com pessoas também pode ser restringido pelas regras internas do modelo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Image Playground 时，某些 prompt 可能会生成失败。涉及人物或人物形象的内容也可能因模型内置限制而无法生成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Image Playground 時，某些 prompt 可能會生成失敗。涉及人物或人物形象的內容也可能因模型內建限制而無法生成。"
          }
        }
      }
    },
