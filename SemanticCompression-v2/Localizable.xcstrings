          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "중요: Image Playground는 일부 프롬프트에서 생성에 실패할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importante: o Image Playground pode falhar com alguns prompts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注意：Image Playground 在部分 prompt 上可能生成失败。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "注意：Image Playground 在部分 prompt 上可能生成失敗。"
          }
        }
      }
    },
