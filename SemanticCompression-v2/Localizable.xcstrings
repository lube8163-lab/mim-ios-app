    "settings.image_playground.style.sketch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch preserves more linework and gives results a rougher drawing-like feel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch preserva más líneas y da un resultado más parecido a un dibujo áspero."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch は線の印象が残りやすく、ラフなドローイング寄りの見た目になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch는 선을 더 잘 살리고 거친 드로잉 느낌을 줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch preserva mais traços e dá aos resultados um aspecto mais rascunhado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch 会保留更多线条感，整体更接近草图或手绘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Sketch 會保留更多线條感，整體更接近草圖或手绘。"
          }
        }
      }
    },
