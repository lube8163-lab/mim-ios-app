    "onboarding.explainer.reconstruct.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Viewed images are regenerated on the viewer's device, so results can vary slightly by backend and post mode."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las imágenes vistas se regeneran en el dispositivo del espectador, por lo que el resultado puede variar ligeramente según el backend y el modo de publicación."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示画像は見る人の端末で再生成されるため、backend や投稿モードに応じて結果が少し変わります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표시 이미지는 보는 사람의 기기에서 다시 생성되므로, 백엔드와 게시 모드에 따라 결과가 조금 달라질 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As imagens visualizadas são regeneradas no dispositivo de quem vê, então o resultado pode variar um pouco conforme o backend e o modo de postagem."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示图像会在查看者设备端重新生成，因此会因 backend 和发布模式不同而略有差异。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示圖像會在查看者裝置端重新生成，因此會因 backend 和發布模式不同而略有差異。"
          }
        }
      }
    },
