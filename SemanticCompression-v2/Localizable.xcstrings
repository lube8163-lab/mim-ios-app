        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Installed models are used when available; otherwise the app can switch to Apple Vision / Image Playground automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si hay modelos instalados, se usan primero; si no, la app puede cambiar automáticamente a Apple Vision / Image Playground."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加モデルがあればそれを使い、無ければ Apple Vision / Image Playground に自動で切り替えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설치된 모델이 있으면 우선 사용하고, 없으면 Apple Vision / Image Playground로 자동 전환합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelos instalados são usados primeiro; se não houver, o app pode mudar automaticamente para Apple Vision / Image Playground."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有已安装模型时优先使用；没有时会自动切换到 Apple Vision / Image Playground。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "有已安裝模型時優先使用；沒有時會自動切換到 Apple Vision / Image Playground。"
          }
        }
      }
    },
