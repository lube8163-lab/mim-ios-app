    "onboarding.ai_fallback.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You Can Start Without Extra Models"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes empezar sin modelos extra"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AI モデルが未導入でも使えます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추가 모델 없이도 시작할 수 있습니다"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode começar sem modelos extras"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需额外模型也能开始使用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無需額外模型也能開始使用"
          }
        }
      }
    },
    "onboarding.ai_fallback.understanding.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even if no extra model is installed, image understanding can fall back to Apple Vision automatically. You can switch to Qwen or SigLIP2 later from Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aunque no haya modelos extra instalados, la comprensión de imágenes puede cambiar automáticamente a Apple Vision. Más tarde puedes elegir Qwen o SigLIP2 desde Configuración."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加モデルが未導入でも、画像理解は Apple Vision に自動で切り替えられます。あとから設定で Qwen や SigLIP2 に変更できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추가 모델이 없어도 이미지 이해는 Apple Vision으로 자동 전환할 수 있습니다. 나중에 설정에서 Qwen 또는 SigLIP2로 바꿀 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesmo sem modelo extra instalado, o entendimento de imagem pode usar automaticamente o Apple Vision. Depois você pode mudar para Qwen ou SigLIP2 em Configurações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使没有安装额外模型，图像理解也会自动回退到 Apple Vision。之后可在设置中切换到 Qwen 或 SigLIP2。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即使沒有安裝額外模型，圖像理解也會自動回退到 Apple Vision。之後可在設定中切換到 Qwen 或 SigLIP2。"
          }
        }
      }
    },
