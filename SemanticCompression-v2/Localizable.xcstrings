    "settings.alert.clear_cache.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This deletes regenerated image cache and also removes retained originals, semantic scores, and LPIPS distances from Pro Mode. Visible post images will regenerate again if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la caché de imágenes regeneradas y también quita originales retenidos, puntuaciones semánticas y distancias LPIPS del Modo Pro. Las imágenes visibles podrán regenerarse de nuevo si hace falta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "再生成画像キャッシュを削除し、プロモードで保持していた元画像キャッシュ、意味スコア、LPIPS知覚距離も消去します。表示中の投稿画像は必要に応じて再生成されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재생성 이미지 캐시를 삭제하고, 프로 모드가 보관한 원본, 의미 점수, LPIPS 거리도 함께 제거합니다. 필요하면 보이는 게시물 이미지는 다시 생성됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto exclui o cache de imagens regeneradas e também remove originais retidos, pontuações semânticas e distâncias LPIPS do Modo Pro. As imagens visíveis poderão ser regeneradas novamente se necessário."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会删除重建图片缓存，也会清除专业模式保留的原图缓存、语义评分和LPIPS感知距离。当前可见的帖子图片会在需要时重新生成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會刪除重建圖片缓存，也會清除专业模式保留的原圖缓存、語義评分和LPIPS感知距离。当前可见的帖子圖片會在需要時重新生成。"
          }
        }
      }
    },
    "settings.alert.clear_cache.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
