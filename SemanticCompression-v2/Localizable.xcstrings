    "new_post.l4_warning.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "L4 improves reconstruction but weakens privacy. Continue?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "L4 mejora la reconstrucción pero reduce la privacidad. ¿Continuar?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "L4 は再現性が高い一方、プライバシーは弱くなります。続行しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "L4는 재구성 품질을 높이지만 프라이버시는 약해집니다. 계속할까요?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O L4 melhora a reconstrução, mas enfraquece a privacidade. Continuar?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "L4 会提升重建效果，但会削弱隐私保护。要继续吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "L4 會提升重建效果，但會削弱隱私保護。要繼續嗎？"
          }
        }
      }
    },
