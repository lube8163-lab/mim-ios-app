    "model_management.intro.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use this screen to download, remove, or switch local models. Automatic, Apple Vision, and Image Playground behavior is chosen separately in Settings under AI Backends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa esta pantalla para descargar, eliminar o cambiar modelos locales. El comportamiento de Automático, Apple Vision e Image Playground se elige por separado en Configuración, dentro de Backends de IA."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここでは追加モデルのダウンロードや削除、ローカルモデル同士の切替を行えます。Automatic / Apple Vision / Image Playground などの使い分けは設定画面の「AI バックエンド」で選びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 화면에서 로컬 모델을 다운로드, 삭제, 전환할 수 있습니다. Automatic, Apple Vision, Image Playground 동작은 설정의 AI 백엔드에서 따로 고를 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esta tela para baixar, remover ou trocar modelos locais. O comportamento de Automático, Apple Vision e Image Playground é escolhido separadamente em Configurações, na seção de Backends de IA."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此页面用于下载、删除或切换本地模型。Automatic、Apple Vision、Image Playground 等行为需在设置里的 AI Backends 中选择。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此頁面用於下載、刪除或切換本地模型。Automatic、Apple Vision、Image Playground 等行為需在設定裡的 AI Backends 中選擇。"
          }
        }
      }
    },
