    "onboarding.ai_fallback.generation.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If Stable Diffusion is not installed, image generation can fall back to Image Playground. Some prompts may fail, and person-related imagery can also be restricted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Stable Diffusion no está instalado, la generación de imágenes puede cambiar a Image Playground. Algunos prompts pueden fallar y el contenido relacionado con personas también puede estar restringido."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion が未導入でも、画像生成は Image Playground に切り替えられます。ただし一部のプロンプトは失敗し、人物表現などは制限されることがあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable Diffusion이 없어도 이미지 생성은 Image Playground로 전환할 수 있습니다. 다만 일부 프롬프트는 실패할 수 있고, 사람 관련 이미지는 제한될 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o Stable Diffusion não estiver instalado, a geração de imagem pode usar o Image Playground. Alguns prompts podem falhar, e conteúdo relacionado a pessoas também pode ser restringido."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果未安装 Stable Diffusion，图像生成会回退到 Image Playground。部分 prompt 可能失败，涉及人物的内容也可能受到限制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果未安裝 Stable Diffusion，圖像生成會回退到 Image Playground。部分 prompt 可能失敗，涉及人物的內容也可能受到限制。"
          }
        }
      }
    },
    "onboarding.ai_fallback.generation.emphasis": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Important: Image Playground can fail on some prompts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importante: Image Playground puede fallar con algunos prompts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
