          }
        }
      }
    },
    "privacy_mode.description.l3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sends low-frequency DCT coefficients for balanced reconstruction/privacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía coeficientes DCT de baja frecuencia para equilibrar reconstrucción y privacidad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "低周波DCT係数を送信。再現性と保護のバランスを調整。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "재구성과 프라이버시의 균형을 위해 저주파 DCT 계수를 전송합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia coeficientes DCT de baixa frequência para equilibrar reconstrução e privacidade."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送低频 DCT 系数，在重建效果与隐私之间取得平衡。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送低頻 DCT 系数，在重建效果與隱私之间取得平衡。"
          }
        }
      }
    },
    "privacy_mode.description.l4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sends extreme low-res pixels. Better reconstruction, weaker privacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía píxeles de resolución extremadamente baja. Mejor reconstrucción, menor privacidad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "極低解像ピクセルを送信。再現性は高いが保護は弱め。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "극저해상도 픽셀을 전송합니다. 재구성은 더 좋지만 프라이버시는 약합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia pixels em resolução extremamente baixa. Melhor reconstrução, privacidade mais fraca."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送极低分辨率像素。重建更好，但隐私保护较弱。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送极低分辨率像素。重建更好，但隱私保护较弱。"
          }
        }
      }
    },
