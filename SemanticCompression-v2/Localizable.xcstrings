    "app_info.ai_backend_labels.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Image posts can show which image-understanding backend produced their semantic metadata.\nThis helps viewers interpret caption/prompt differences and reconstruction variance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las publicaciones de imagen pueden mostrar qué backend de comprensión de imágenes produjo sus metadatos semánticos.\nEsto ayuda a interpretar diferencias en caption/prompt y variaciones en la reconstrucción."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像投稿には、その semantic 情報がどの画像理解 backend で作られたかを表示できます。\nこれにより、閲覧者は caption / prompt の傾向差や再生成画像の揺れを解釈しやすくなります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Postagens com imagem podem mostrar qual backend de entendimento de imagem produziu seus metadados semânticos.\nIsso ajuda a interpretar diferenças de caption/prompt e variações na reconstrução."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图片帖子可以显示其语义元数据由哪个图像理解后端生成。\n这样更容易理解 caption / prompt 的差异以及重建图像的波动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "圖片貼文可以顯示其語義元資料由哪個圖像理解後端生成。\n這樣更容易理解 caption / prompt 的差異以及重建圖像的波動。"
          }
        }
      }
    },
