    "onboarding.ai_fallback.settings.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the AI Backends section in Settings, you can choose the image-understanding backend, the image-generation backend, and the Image Playground style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En la sección de Backends de IA de Configuración puedes elegir el backend de comprensión de imágenes, el backend de generación y el estilo de Image Playground."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定画面の「AI バックエンド」から、画像理解・画像生成の backend や、Image Playground のスタイルを選べます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정의 AI 백엔드 항목에서 이미지 이해 백엔드, 이미지 생성 백엔드, Image Playground 스타일을 선택할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Na seção de Backends de IA em Configurações você pode escolher o backend de entendimento de imagem, o backend de geração de imagem e o estilo do Image Playground."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以在设置里的 AI Backends 中选择图像理解后端、图像生成后端，以及 Image Playground 风格。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以在設定裡的 AI Backends 中選擇圖像理解後端、圖像生成後端，以及 Image Playground 風格。"
          }
        }
      }
    },
