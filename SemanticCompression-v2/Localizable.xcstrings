    },
    "privacy_mode.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the default privacy mode for posting. The selected mode changes the intermediate payload sent and how the initial image is reconstructed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el modo de privacidad predeterminado para publicar. El modo seleccionado cambia el payload intermedio enviado y la forma en que se reconstruye la imagen inicial."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "投稿時に使う既定のプライバシーモードを選択します。モードに応じて、送信する中間表現と再構成のされ方が変わります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게시 시 기본 프라이버시 모드를 선택합니다. 선택한 모드에 따라 전송되는 중간 표현과 초기 이미지 재구성 방식이 바뀝니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o modo de privacidade padrão para postar. O modo selecionado altera o payload intermediário enviado e a forma como a imagem inicial é reconstruída."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择发帖时默认使用的隐私模式。不同模式会改变发送的中间表示以及初始图像的重建方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇發帖時預設使用的隱私模式。不同模式會改變傳送的中間表示以及初始圖像的重建方式。"
          }
        }
      }
    },
    "privacy_mode.description.l1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No image payload is sent. Lowest reconstruction, highest privacy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se envía payload de imagen. Menor reconstrucción, mayor privacidad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像情報を送信しない。再現性は低いがプライバシー最優先。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지 페이로드를 보내지 않습니다. 재구성은 가장 낮고 프라이버시는 가장 높습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum payload de imagem é enviado. Menor reconstrução, maior privacidade."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不发送图像信息。重建能力最低，但隐私保护最高。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不傳送圖像信息。重建能力最低，但隱私保护最高。"
          }
        }
      }
    },
    "privacy_mode.description.l2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sends a compact summary (ThumbHash). Recommended default mode."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
